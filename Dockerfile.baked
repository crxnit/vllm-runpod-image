# Multi-stage build: download model on native arch, copy into amd64 runtime image.
# Use this when you want model weights baked into the image for zero-download boot.
#
# Build:
#   docker buildx build --platform linux/amd64 -f Dockerfile.baked -t youruser/vllm-coder-baked:latest --push .

# Stage 1: Download model weights on the build host's native architecture (fast, no emulation)
FROM --platform=$BUILDPLATFORM python:3.11 AS downloader

RUN pip install --no-cache-dir "huggingface_hub[cli,hf_xet]"

ARG MODEL=Qwen/Qwen2.5-Coder-32B-Instruct-AWQ
RUN huggingface-cli download ${MODEL} --local-dir /models/weights

# Stage 2: amd64 runtime image with vLLM + pre-downloaded weights
FROM --platform=linux/amd64 vllm/vllm-openai:v0.6.3

RUN pip install --no-cache-dir huggingface_hub tiktoken

ENV HF_HOME=/root/.cache/huggingface
ENV VLLM_WORKER_MULTIPROC_METHOD=spawn

# Copy model weights from the downloader stage
COPY --from=downloader /models/weights /models/weights

COPY scripts/pre_start.sh /pre_start.sh
COPY scripts/post_start.sh /post_start.sh
RUN chmod +x /pre_start.sh /post_start.sh

EXPOSE 8000

CMD ["vllm", "serve", "/models/weights", \
     "--quantization", "awq", \
     "--max-model-len", "16384", \
     "--port", "8000"]
