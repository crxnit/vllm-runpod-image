# Single-stage build: download model weights directly into the runtime image.
# Use this when you want model weights baked into the image for zero-download boot.
#
# For GitHub Actions (runner is native amd64 — no emulation, no multi-stage needed):
#   docker buildx build --platform linux/amd64 -f Dockerfile.baked -t youruser/vllm-coder-baked:latest --push .
#
# For Apple Silicon (local build — uses QEMU, will be slow for the download step):
#   docker buildx build --platform linux/amd64 -f Dockerfile.baked -t youruser/vllm-coder-baked:latest --push .
#   Consider using GitHub Actions instead to avoid emulation overhead.

FROM vllm/vllm-openai:v0.6.3

RUN pip install --no-cache-dir "huggingface_hub[cli,hf_xet]" tiktoken

ENV HF_HOME=/root/.cache/huggingface
ENV VLLM_WORKER_MULTIPROC_METHOD=spawn

# Download model weights directly into the image (no duplication across stages)
ARG MODEL=Qwen/Qwen2.5-Coder-32B-Instruct-AWQ
RUN python3 -c "from huggingface_hub import snapshot_download; snapshot_download('${MODEL}', local_dir='/models/weights')"

COPY scripts/pre_start.sh /pre_start.sh
COPY scripts/post_start.sh /post_start.sh
RUN chmod +x /pre_start.sh /post_start.sh

EXPOSE 8000

CMD ["vllm", "serve", "/models/weights", \
     "--quantization", "awq", \
     "--max-model-len", "16384", \
     "--port", "8000"]
