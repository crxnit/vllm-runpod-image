# vLLM RunPod backend URL (include https://, no trailing slash)
VLLM_BACKEND=https://your-pod-id-8000.proxy.runpod.net

# vLLM API key (the VLLM_API_KEY set in your RunPod template)
VLLM_API_KEY=your-vllm-api-key

# Traefik basic auth credentials (generate with: htpasswd -nB kate)
# IMPORTANT: double all $ signs for docker-compose ($ -> $$)
TRAEFIK_BASIC_AUTH=kate:$$2y$$05$$hash-goes-here
